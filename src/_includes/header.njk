<header class="site-header" id="site-header">
  <div class="header-inner">
    <a class="header-logo" href="{{ '/' | url }}">
      <img src="{{ '/images/misc/Thai-Emblem_white.png' | url }}" class="header-emblem" alt="">
      <span>Ron Domingue</span>
    </a>
    <nav class="header-nav">
      <a href="{{ '/work/' | url }}" class="nav-link {% if navActive == 'work' %}active{% endif %}">Work</a>
      <a href="{{ '/about/' | url }}" class="nav-link {% if navActive == 'about' %}active{% endif %}">About</a>
      <a href="{{ site.fieldGuideUrl }}" class="nav-link" target="_blank">Field Guide ↗</a>
    </nav>
  </div>
</header>
