      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="scroll-hint" id="scroll-hint">
    <svg viewBox="0 0 24 32" fill="none">
      <line x1="12" y1="2" x2="12" y2="26" stroke="rgba(238,238,240,0.5)" stroke-width="1.5" stroke-linecap="round"/>
      <polyline points="4,18 12,27 20,18" fill="none" stroke="rgba(238,238,240,0.7)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

</section>

<!-- WORK GRID -->
<section class="work-section" id="work">
  <div class="work-header">
    <span class="section-label">Selected Work</span>
    <span class="section-count">{{ projects | length }} projects</span>
  </div>

  <div class="work-grid">
    {% for project in projects %}
    <a class="work-card {% if loop.first %}work-card--featured{% endif %}" href="{{ ('/work/' + project.slug + '/') | url }}">
      <div class="work-card-img" style="background-image: url('{{ ('/' + project.thumb) | url }}')"></div>
      <div class="work-card-overlay"></div>
      <div class="work-card-info">
        <div class="work-card-tags">
          {% for tag in project.tags %}<span class="work-tag">{{ tag }}</span>{% endfor %}
          <span class="work-tag">{{ project.year }}</span>
        </div>
        <div class="work-card-title">{{ project.title }}</div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>

<script>
  // ── Eyebrow widget ──────────────────────────────────────────────
  const glitchChars = '▓░▒█╬╫╪┼╂╀┿╃╄╅╆╇╈╉╊╋⌬⌭⌮⌯⌰⌱⌲⌳⌴⌵⌶⌷⌸⌹⌺⌻⌼⌽⌾⌿XZKVWMB#@!?%&';

  function glitchType(el, finalText, delay = 0, speed = 45) {
    let resolved = 0;
    const len = finalText.length;
    let frame = 0;
    el.textContent = '';
    setTimeout(() => {
      el.style.opacity = '1';
      const interval = setInterval(() => {
        let output = '';
        for (let i = 0; i < len; i++) {
          if (i < resolved) {
            output += Math.random() < 0.04
              ? glitchChars[Math.floor(Math.random() * glitchChars.length)]
              : finalText[i];
          } else {
            output += glitchChars[Math.floor(Math.random() * glitchChars.length)];
          }
        }
        el.textContent = output;
        frame++;
        const roll = Math.random();
        if (roll < 0.5 && resolved < len) resolved++;
        else if (roll < 0.65 && resolved < len) resolved += 2;
        if (resolved >= len) {
          el.textContent = finalText;
          clearInterval(interval);
        }
      }, speed);
    }, delay);
  }

  const pageLoadTime = Date.now();

  function formatTC(ms) {
    const totalFrames = Math.floor(ms / (1000 / 24));
    const frames = totalFrames % 24;
    const secs   = Math.floor(totalFrames / 24) % 60;
    const mins   = Math.floor(totalFrames / 24 / 60) % 60;
    const hrs    = Math.floor(totalFrames / 24 / 3600);
    return [hrs, mins, secs].map(n => String(n).padStart(2,'0')).join(':') + ':' + String(frames).padStart(2,'0');
  }

  function getNDStop(lux) {
    if (lux > 80000) return 'ND 1.8';
    if (lux > 40000) return 'ND 1.5';
    if (lux > 20000) return 'ND 1.2';
    if (lux > 10000) return 'ND 0.9';
    if (lux > 5000)  return 'ND 0.6';
    if (lux > 1000)  return 'ND 0.3';
    return 'CLEAR';
  }

  function getConditionLabel(code) {
    if (code === 0) return 'CLEAR';
    if (code <= 3)  return 'PARTLY CLOUDY';
    if (code <= 48) return 'OVERCAST / FOG';
    if (code <= 67) return 'RAIN';
    if (code <= 77) return 'SNOW';
    if (code <= 82) return 'SHOWERS';
    return 'STORM';
  }

  function getSunElevLabel(el) {
    if (el > 60) return 'OVERHEAD';
    if (el > 30) return 'MID SKY';
    if (el > 10) return 'LOW SUN';
    if (el > 0)  return 'GOLDEN HOUR';
    return 'NIGHT';
  }

  async function loadExposure() {
    let lat = 29.9511, lon = -90.0715;
    try {
      const geo = await fetch('https://ipapi.co/json/');
      const gd  = await geo.json();
      if (gd.latitude) { lat = gd.latitude; lon = gd.longitude; }
    } catch(e) {}

    const latStr  = Math.abs(lat).toFixed(4) + '°' + (lat >= 0 ? 'N' : 'S');
    const lonStr  = Math.abs(lon).toFixed(4) + '°' + (lon >= 0 ? 'E' : 'W');
    const coordStr = `${latStr} ${lonStr}`;

    glitchType(document.getElementById('glitch-eyebrow'), coordStr, 0, 55);

    setTimeout(() => {
      const eyebrow = document.getElementById('glitch-eyebrow');
      function tickRow1() {
        eyebrow.textContent = `${coordStr} / ${formatTC(Date.now() - pageLoadTime)}`;
        requestAnimationFrame(tickRow1);
      }
      tickRow1();
    }, 2200);

    try {
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=weather_code,direct_radiation&daily=sunrise,sunset&timezone=auto&forecast_days=1`;
      const res  = await fetch(url);
      const data = await res.json();
      const code  = data.current.weather_code;
      const lux   = (data.current.direct_radiation || 0) * 120;
      const now   = new Date();
      const rise  = new Date(data.daily.sunrise[0]);
      const set   = new Date(data.daily.sunset[0]);
      const elapsed = (now - rise) / 1000;
      const dayLen  = (set - rise) / 1000;
      const sunEl   = Math.round(Math.sin((elapsed / dayLen) * Math.PI) * 90);
      const condition = getConditionLabel(code);
      const sunLabel  = getSunElevLabel(sunEl);
      const nd        = getNDStop(lux);
      const tcEl = document.getElementById('exposure-eyebrow');
      tcEl.style.opacity = '1';
      function tickExposure() {
        tcEl.textContent = `${condition} / ${sunLabel} / T2.8 / 1/24S / ISO 800 / ${nd}`;
        requestAnimationFrame(tickExposure);
      }
      tickExposure();
    } catch(e) {
      const tcEl = document.getElementById('exposure-eyebrow');
      tcEl.style.opacity = '1';
      tcEl.textContent = 'CLEAR / NIGHT / T2.8 / 1/24S / ISO 800 / NO ND';
    }
  }

  loadExposure();

  // ── Scroll hint ─────────────────────────────────────────────────
  window.addEventListener('scroll', () => {
    const hint = document.getElementById('scroll-hint');
    if (hint) hint.style.opacity = window.scrollY > 60 ? '0' : '1';
  }, { passive: true });
</script>
