---
layout: base.njk
bodyClass: page-home
---

<!-- HERO -->
<section class="hero">

  <!-- Vimeo background reel -->
  <div class="hero-video-wrap">
    <iframe
      class="hero-video"
      src="https://player.vimeo.com/video/{{ site.vimeoReel }}?background=1&autoplay=1&loop=1&muted=1&quality=1080p"
      allow="autoplay; fullscreen"
      allowfullscreen
      frameborder="0">
    </iframe>
  </div>

  <div class="hero-overlay"></div>

  <div class="hero-content">
    <!-- Eyebrow row 1 — glitch coords → live timecode -->
    <div class="hero-eyebrow" id="glitch-eyebrow"></div>
    <!-- Eyebrow row 2 — live weather / exposure -->
    <div class="hero-eyebrow" id="exposure-eyebrow" style="opacity:0;"></div>

    <h1 class="hero-title">
      <span class="hero-emblem-wrap">
        <img src="{{ '/images/misc/Thai-Emblem_white.png' | url }}" class="hero-emblem" alt="">
      </span>
      Ron <em>Domingue</em>
    </h1>

    <p class="hero-role">Art Director / Visual Artist</p>

    <p class="hero-desc">
      New Orleans-based art director and visual artist. Environment art and cinematic short films built in Unreal Engine 5 — Nanite, Lumen, volumetric lighting, real-world camera settings inside the engine.
    </p>

    <div class="hero-cta">
      <a href="/work/" class="btn-ghost">Work</a>
      <a href="/about/" class="btn-ghost">About</a>
      <a href="{{ site.fieldGuideUrl }}" class="btn-ghost" target="_blank">Field Guide</a>
    </div>

    <div class="hero-social">
